# AO Development Container
#
# Provides a complete build environment for AO (Rust + Node.js + Tauri Linux deps).
# Use with docker-compose.yml for bind-mount development workflow.
#
# Build:   docker build -f docker/Dockerfile.dev -t ao-dev .
# Run:     docker run -it -v $(pwd):/workspace ao-dev
#
# Ref: https://v2.tauri.app/start/prerequisites/#linux

FROM rust:1.84-bookworm

LABEL maintainer="AO's Mentor"
LABEL description="AO development environment with Rust, Node.js 20, and Tauri 2 Linux dependencies"

# Avoid interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# ── System dependencies for Tauri 2 on Linux ──────────────────────────────
# Ref: https://v2.tauri.app/start/prerequisites/#linux
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Tauri 2 core deps
    libwebkit2gtk-4.1-dev \
    libappindicator3-dev \
    libayatana-appindicator3-dev \
    librsvg2-dev \
    patchelf \
    libssl-dev \
    libgtk-3-dev \
    # Build essentials
    build-essential \
    curl \
    wget \
    pkg-config \
    file \
    # eframe/egui deps (for ao-keygen)
    libxcb-render0-dev \
    libxcb-shape0-dev \
    libxcb-xfixes0-dev \
    libxkbcommon-dev \
    # Utilities
    git \
    jq \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js 20 LTS ────────────────────────────────────────────────────────
# Ref: https://github.com/nodesource/distributions
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# ── Rust tooling ──────────────────────────────────────────────────────────
RUN rustup component add clippy rustfmt \
    && cargo install cargo-audit \
    && cargo install tauri-cli --version "^2"

# ── Non-root user ─────────────────────────────────────────────────────────
RUN useradd -m -s /bin/bash ao-dev
USER ao-dev

WORKDIR /workspace

# Default entrypoint: interactive shell for development
ENTRYPOINT ["/bin/bash"]
