{
  "id": "dynamic.slack",
  "name": "Slack",
  "description": "Send messages and list channels in Slack workspaces via the Slack Web API.",
  "version": "1.0.0",
  "category": "Integration",
  "created_at": "2026-02-19T00:00:00Z",
  "tools": [
    {
      "name": "slack_send_message",
      "description": "Send a message to a Slack channel. Requires the channel ID (not the name).",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "description": "Slack channel ID (e.g. C01234ABCDE)"
          },
          "text": {
            "type": "string",
            "description": "Message text (supports Slack mrkdwn formatting)"
          }
        },
        "required": ["channel", "text"]
      },
      "method": "POST",
      "url_template": "https://slack.com/api/chat.postMessage",
      "headers": {
        "Authorization": "Bearer {{secret:slack_bot_token}}",
        "Content-Type": "application/json"
      },
      "body_template": "{\"channel\": \"{{channel}}\", \"text\": \"{{text}}\"}",
      "response_extract": {
        "ok": "ok",
        "ts": "ts",
        "channel": "channel"
      },
      "response_format": null
    },
    {
      "name": "slack_list_channels",
      "description": "List public channels in the Slack workspace. Use to find channel IDs for sending messages.",
      "parameters": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "description": "Max channels to return (default 100, max 1000)",
            "default": 100
          }
        }
      },
      "method": "GET",
      "url_template": "https://slack.com/api/conversations.list?types=public_channel&limit={{limit}}",
      "headers": {
        "Authorization": "Bearer {{secret:slack_bot_token}}"
      },
      "body_template": null,
      "response_extract": {},
      "response_format": null
    }
  ]
}
