{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["tauri-app/src-ui/node_modules/vite/bin/vite.js", "tauri-app/src-ui", "--config", "tauri-app/src-ui/vite.config.ts", "--port", "1420", "--strictPort"],
      "port": 1420
    },
    {
      "name": "hive-daemon",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["run", "-p", "hive-daemon", "--", "--port", "3141"],
      "port": 3141
    },
    {
      "name": "entity-daemon",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["run", "-p", "entity-daemon", "--", "--entity-id", "00000000-0000-0000-0000-000000000000", "--hive-url", "http://127.0.0.1:3141", "--port", "3142"],
      "port": 3142
    },
    {
      "name": "tauri-app",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["tauri", "dev"],
      "port": 1420
    }
  ]
}
