{
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "",
    "frontendDist": "src-ui/dist"
  },
  "package": {
    "productName": "Abby",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "open": false }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.abby.app",
      "icon": [],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      },
      "longDescription": "Abby - Abigail Normal",
      "shortDescription": "Abby agent",
      "resources": [],
      "externalBin": [],
      "copyright": "",
      "category": "Developer",
      "shortcut": true,
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Abby",
        "width": 800,
        "height": 600
      }
    ]
  }
}
